  <sgraph:Statechart xmi:id="_9Qy08HyXEe2ua6MSQyC-Ag" specification="// Use the event driven execution model.&#xA;// Switch to cycle based behavior&#xA;// by specifying '@CycleBased(200)'.&#xA;@EventDriven&#xA;&#xA;// Use @SuperSteps(yes) to enable&#xA;// super step semantics.&#xA;@SuperSteps(no)&#xA;&#x9;&#xA;interface system:&#xA;&#x9;in event on&#xA;&#x9;in event off&#xA;&#x9;var isOn: boolean = false&#xA;&#x9;var door_status: string = &quot;Door Closed&quot;&#xA;&#x9;&#xA;interface door:&#xA;&#x9;var open_time: integer = 30&#xA;&#x9;var current_open_time: integer = 0&#xA;&#x9;var auto_timeout: integer = 50&#xA;&#x9;in event opened&#xA;&#x9;in event closed&#xA;&#x9;in event re_open&#xA;&#x9;&#xA;&#x9;// Controlled outside&#xA;&#x9;var block: boolean = false&#xA;&#x9;var door_closed: boolean = true&#xA;&#x9;in event open_door&#xA;&#x9;in event close_door&#xA;&#x9;" name="GarageDoor_Unit">
    <regions xmi:id="_9Q6Js3yXEe2ua6MSQyC-Ag" name="&lt;GarageDoor_Unit>">
      <vertices xsi:type="sgraph:Entry" xmi:id="_9Q6JtHyXEe2ua6MSQyC-Ag">
        <outgoingTransitions xmi:id="_9Q6JtXyXEe2ua6MSQyC-Ag" target="_LvpEIHyYEe2ua6MSQyC-Ag"/>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_9Q7X0HyXEe2ua6MSQyC-Ag" specification="entry / system.isOn = true" name="doorInUse" incomingTransitions="_Ol_mMHyYEe2ua6MSQyC-Ag">
        <outgoingTransitions xmi:id="_P7pxkHyYEe2ua6MSQyC-Ag" specification="every 500ms [!system.isOn]" target="_LvpEIHyYEe2ua6MSQyC-Ag"/>
        <outgoingTransitions xmi:id="_YBLlsI2YEe2zy72EqUM_2Q" specification="system.off" target="_LvpEIHyYEe2ua6MSQyC-Ag"/>
        <regions xmi:id="_CP1h0HyYEe2ua6MSQyC-Ag" name="&lt;Door_Working>">
          <vertices xsi:type="sgraph:State" xmi:id="_eTrLYI3ZEe6Uzct5TWOUNg" specification="entry/&#xD;&#xA;door.current_open_time = 0;&#xD;&#xA;door.door_closed = true;&#xD;&#xA;system.door_status = &quot;Door Closed&quot;&#xD;&#xA;&#xD;&#xA;after door.auto_timeout s/&#xD;&#xA;system.isOn = false&#xD;&#xA;&#xD;&#xA;exit/&#xD;&#xA;door.door_closed = false" name="door_closed" incomingTransitions="_j_T4gI3ZEe6Uzct5TWOUNg _zulNwI3ZEe6Uzct5TWOUNg">
            <outgoingTransitions xmi:id="_tpKusI3ZEe6Uzct5TWOUNg" specification="door.open_door" target="_ldtJII3ZEe6Uzct5TWOUNg"/>
          </vertices>
          <vertices xsi:type="sgraph:Entry" xmi:id="_iYzNsI3ZEe6Uzct5TWOUNg" kind="SHALLOW_HISTORY">
            <outgoingTransitions xmi:id="_j_T4gI3ZEe6Uzct5TWOUNg" specification="" target="_eTrLYI3ZEe6Uzct5TWOUNg"/>
          </vertices>
          <vertices xsi:type="sgraph:State" xmi:id="_ldtJII3ZEe6Uzct5TWOUNg" specification="entry/ &#xD;&#xA;door.current_open_time += 1;&#xD;&#xA;system.door_status = &quot;Door Opening&quot;&#xD;&#xA;always [door.current_open_time >= door.open_time]/ raise door.opened" name="door_opening" incomingTransitions="_tpKusI3ZEe6Uzct5TWOUNg _2ew2YI3ZEe6Uzct5TWOUNg _vOk7YI3bEe6Uzct5TWOUNg">
            <outgoingTransitions xmi:id="_vVefgI3ZEe6Uzct5TWOUNg" specification="door.opened" target="_nJxCUI3ZEe6Uzct5TWOUNg"/>
            <outgoingTransitions xmi:id="_vOk7YI3bEe6Uzct5TWOUNg" specification="every 1s" target="_ldtJII3ZEe6Uzct5TWOUNg"/>
          </vertices>
          <vertices xsi:type="sgraph:State" xmi:id="_nJxCUI3ZEe6Uzct5TWOUNg" specification="entry/ &#xD;&#xA;door.current_open_time = door.open_time;&#xD;&#xA;system.door_status = &quot;Door Opened&quot;&#xD;&#xA;after door.auto_timeout s/ raise door.close_door" name="door_opened" incomingTransitions="_vVefgI3ZEe6Uzct5TWOUNg">
            <outgoingTransitions xmi:id="_119J8I3ZEe6Uzct5TWOUNg" specification="door.close_door" target="_ojB7UI3ZEe6Uzct5TWOUNg"/>
          </vertices>
          <vertices xsi:type="sgraph:State" xmi:id="_ojB7UI3ZEe6Uzct5TWOUNg" specification="entry/ &#xD;&#xA;door.current_open_time -= 1;&#xD;&#xA;system.door_status = &quot;Door Closing&quot;&#xD;&#xA;always [door.current_open_time &lt;= 0]/ raise door.closed" name="door_closing" incomingTransitions="_119J8I3ZEe6Uzct5TWOUNg __rQ60I3cEe6Uzct5TWOUNg">
            <outgoingTransitions xmi:id="_zulNwI3ZEe6Uzct5TWOUNg" specification="door.closed [door.current_open_time == 0]" target="_eTrLYI3ZEe6Uzct5TWOUNg"/>
            <outgoingTransitions xmi:id="_2ew2YI3ZEe6Uzct5TWOUNg" specification="door.re_open" target="_ldtJII3ZEe6Uzct5TWOUNg"/>
            <outgoingTransitions xmi:id="__rQ60I3cEe6Uzct5TWOUNg" specification="every 1s" target="_ojB7UI3ZEe6Uzct5TWOUNg"/>
            <regions xmi:id="_BmqX4I3aEe6Uzct5TWOUNg" name="&lt;Block_Status>">
              <vertices xsi:type="sgraph:State" xmi:id="_JtcRwI3aEe6Uzct5TWOUNg" specification="entry/ &#xD;&#xA;door.block = false" name="no_block" incomingTransitions="_Vdq-kI3aEe6Uzct5TWOUNg">
                <outgoingTransitions xmi:id="_WkYH8I3aEe6Uzct5TWOUNg" specification="every 100ms [door.block]" target="_SaKKQI3aEe6Uzct5TWOUNg"/>
              </vertices>
              <vertices xsi:type="sgraph:State" xmi:id="_SaKKQI3aEe6Uzct5TWOUNg" specification="entry/&#xD;&#xA;raise door.re_open" name="block" incomingTransitions="_WkYH8I3aEe6Uzct5TWOUNg"/>
              <vertices xsi:type="sgraph:Entry" xmi:id="_UdQDYI3aEe6Uzct5TWOUNg">
                <outgoingTransitions xmi:id="_Vdq-kI3aEe6Uzct5TWOUNg" specification="" target="_JtcRwI3aEe6Uzct5TWOUNg"/>
              </vertices>
            </regions>
          </vertices>
        </regions>
      </vertices>
      <vertices xsi:type="sgraph:State" xmi:id="_LvpEIHyYEe2ua6MSQyC-Ag" specification="entry/&#xA;system.isOn = false" name="doorOff" incomingTransitions="_9Q6JtXyXEe2ua6MSQyC-Ag _P7pxkHyYEe2ua6MSQyC-Ag _YBLlsI2YEe2zy72EqUM_2Q">
