  <sgraph:Statechart xmi:id="_UCD7gITWEe2xcIFyeWpeZw" specification="@EventDriven&#xA;@ChildFirstExecution&#xA;&#xA;interface:&#xA;&#x9;// Define events and variables here. &#xA;&#x9;// Use CTRL + Space for content assist.&#xA;&#x9;&#x9;var warned: boolean&#xA;&#x9;&#x9;&#xA;&#x9;interface Timer:&#xA;&#x9;&#x9;in event enable&#xA;&#x9;&#x9;in event disable&#xA;&#x9;&#x9;in event reset&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;var counter: integer = 10&#xA;&#x9;&#x9;var warning_period: integer = 15&#xA;&#x9;&#x9;var final_warning_period: integer = 8&#xA;&#x9;&#x9;&#xA;&#x9;interface Message:&#xA;&#x9;&#x9;var status: string&#xA;&#x9;&#x9;var sensor: string&#xA;&#xA;&#x9;interface Mode:&#xA;&#x9;&#x9;in event manual_off&#xA;&#x9;&#x9;in event manual_on&#xA;&#x9;&#x9;in event safe&#xA;&#x9;&#x9;in event warning&#xA;&#x9;&#x9;in event danger&#xA;&#x9;&#x9;in event pause&#xA;&#x9;&#x9;var pause_time: integer = 5&#xA;&#x9;&#x9;&#xA;&#x9;interface Alarm:&#xA;&#x9;&#x9;var threshold_reached:  boolean = false&#xA;&#x9;&#x9;var activated: boolean = false&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;//MANUAL SWITCH&#xA;&#x9;&#x9;out event off&#xA;&#x9;&#x9;out event on&#xA;&#x9;&#x9;&#xA;&#x9;interface Sensors:&#xA;&#x9;&#x9;in event triggered&#xA;&#x9;&#x9;var index: integer&#xA;&#x9;&#x9;var triggerSignal_received: boolean = false&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;var smoke_presence: boolean&#xA;&#x9;&#x9;var flame_presence: boolean&#xA;&#x9;&#x9;var heat_presence: boolean&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;var smoke_value: integer&#xA;&#x9;&#x9;var flame_value: integer&#xA;&#x9;&#x9;var heat_value: integer&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;//Increment can be randomize using JAVA Code&#xA;&#x9;&#x9;var smoke_increment: integer = 1&#xA;&#x9;&#x9;var flame_increment: integer = 1&#xA;&#x9;&#x9;var heat_increment: integer = 1&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;//Threshold&#xA;&#x9;&#x9;var smoke_warning: integer = 50&#xA;&#x9;&#x9;var smoke_threshold: integer = 90&#xA;&#x9;&#x9;var flame_warning: integer = 50&#xA;&#x9;&#x9;var flame_threshold: integer = 90&#xA;&#x9;&#x9;var hear_warning: integer = 50&#xA;&#x9;&#x9;var heat_threshold: integer = 90&#xA;&#x9;&#x9;" name="FireAlarm_Unit">
